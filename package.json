{
  "name": "real-time-chat-application",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run dev:clean && concurrently --names WEB,API --prefix name --restart-tries 999 --restart-after 2000 \"npm run dev:web\" \"npm run dev:api\"",
    "dev:clean": "kill-port 5173 3001",
    "dev:web": "vite frontend --strictPort --config frontend/vite.config.ts",
    "dev:api": "npm --prefix backend/server run dev",
    "build": "tsc -p frontend/tsconfig.json && vite build frontend --config frontend/vite.config.ts",
    "preview": "vite preview frontend --config frontend/vite.config.ts",
    "lint": "eslint frontend --ext ts,tsx"
  },
  "dependencies": {
    "firebase": "^10.8.0",
    "framer-motion": "^12.35.1",
    "lucide-react": "^0.577.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.30.3",
    "react-textarea-autosize": "^8.5.9",
    "react-virtuoso": "^4.18.6",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^9.2.1",
    "kill-port": "^2.0.1",
    "typescript": "^5.3.3",
    "vite": "^5.0.8"
  }
}
