# Example Environment Variables for FREE Stack

# ============================================
# OLLAMA (Local AI - completely free)
# ============================================
VITE_OLLAMA_URL=http://localhost:11434
VITE_OLLAMA_MODEL=mistral

# Available models:
# - mistral (7B, recommended, balanced)
# - neural-chat (7B, faster)
# - orca-mini (3B, very fast but less accurate)
# - dolphin-mixtral (8x7B, slower but smarter)

# ============================================
# JITSI (Video Calls - completely free)
# ============================================
VITE_JITSI_SERVER=meet.jit.si
# Or self-host:
# VITE_JITSI_SERVER=your-jitsi-server.com

# ============================================
# ENCRYPTION (E2E - completely free)
# ============================================
VITE_E2E_ENCRYPTION_ENABLED=true

# ============================================
# FIREBASE (Chat storage - free tier)
# ============================================
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ============================================
# NOTES
# ============================================
# All services are completely FREE
# No credit card required for any service
# No API keys needed for Jitsi (public service)
# Ollama runs locally (no external API calls)
# Firebase free tier: 1GB storage, 100 concurrent users

